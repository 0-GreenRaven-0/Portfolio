        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
      <div class="nav-links" id="nav-links">
        <a href="#who" class="nav-link">Who's This For</a>
        <a href="#services" class="nav-link">Services</a>
        <a href="#portfolio" class="nav-link">Projects</a>
        <a href="#contact" class="nav-link">Work With Me</a>
      </div>
    </nav>
    <div class="hero-content">

      <h1 class="hero-title">
        Let my powerful words bestow<br />conversion &amp; trust upon your offer
      </h1>
      <p class="hero-subheadline">
        And let my words revoke the accursed AI and its generic writing that repels your qualified customers<br />
        <span class="font-fell text-cream/40 text-[0.75rem] tracking-normal normal-case">(No offense to the AI that helped me build this website...)</span>
      </p>


    </div>
  </section>

  <!-- ─── WHO IS THIS FOR ──────────────────────────────────────── -->
  <section id="who" class="who-section-part2">
    <div class="who-wall-wrap who-wall-left">
      <div class="who-triangle who-triangle-left"></div>
      <img src="/frame 1.png" alt="" class="who-wall-corner who-wall-tl" />
