      { name: 'Droparabia - Email 1', href: 'https://docs.google.com/document/d/1Vn3x7Le2cEDn7n33pQ19hG02f17rcrIMoYZhOlj3WmA/edit?usp=sharing' },
      { name: 'Droparabia - Email 2', href: 'https://docs.google.com/document/d/1PPmN-Rt9BZEkOKTDG8tlPtJUHlslZ0qqkllB6S7jpi0/edit?usp=sharing' },
      { name: 'Droparabia - Email 3', href: 'https://docs.google.com/document/d/1E77DT3RQiUelPREDPubJmpS7f9h2Sl4JdiKvsp0WQKg/edit?usp=sharing' },
      { name: 'RSI - Email 1',        href: 'https://docs.google.com/document/d/1Rw0mG7uk4WB_WxtyNNC3uAEbj6hLlQLCAbSeaCp29qo/edit?usp=sharing' },
      { name: 'RSI - Email 2',        href: 'https://docs.google.com/document/d/1hvH7EddiJnf5OAC5lotbTYa0DZG9VKDW-qgpxRu64Y4/edit?usp=sharing' },
    ],
    'webinar-funnel':  [{ name: 'Droparabia Webinar Registration Page', href: 'https://workshop.droparabia.com' }],
    'sales-page':      [
      { name: 'Droparabia Sales Page',                  href: 'https://join.droparabia.com' },
      { name: 'Droparabia Instagram Funnel Sales Page', href: 'https://book.droparabia.com' },
      { name: 'Samara Michael Workshop',                href: 'https://0-greenraven-0.github.io/SamaraMichaelsFBA/' },
    ],
  };

  const titles: Record<string, string> = {
    'landing-page':    'Landing Pages',
    'copywriting':     'Copywriting',
    'scriptwriting':   'Scriptwriting',
    'webpages':        'Webpages',
    'funnel-creation': 'Funnel Creation',
    'email-marketing': 'Email Marketing',
    'sales-page':      'Sales Pages',
    'webinar-funnel':  'Webinar Landing Pages',
  };

  const overlay = document.getElementById('portfolio-overlay')!;
  const portfolioHeading = document.getElementById('portfolio-heading')!;
  const overlayTitle = document.getElementById('portfolio-overlay-title')!;
  const projectList = document.getElementById('portfolio-project-list')!;
  const backBtn = document.getElementById('portfolio-back')!;
  const portfolioGrid = document.querySelector('.portfolio-grid') as HTMLElement;

  function renderList(items: ListItem[]) {
    items.forEach(p => {
      const li = document.createElement('li');
      const a = p.href === '#' ? document.createElement('span') : document.createElement('a');
      if (a instanceof HTMLAnchorElement) a.href = p.href;
      a.textContent = p.name;
      a.classList.add('portfolio-project-item');
      if (p.href === '#') a.classList.add('portfolio-project-coming-soon');
      a.style.opacity = '0';
      a.style.transform = 'translateY(8px)';
      li.appendChild(a);
      projectList.appendChild(li);
    });
  }

  function handleBackToGrid() {
    const items = projectList.querySelectorAll<HTMLElement>('.portfolio-project-item');
    items.forEach(item => { item.style.opacity = '0'; item.style.transform = 'translateY(8px)'; });
    setTimeout(() => {
      overlay.style.display = 'none';
      portfolioHeading.style.visibility = '';
      portfolioGrid.style.visibility = '';
      const gridCards = portfolioGrid.querySelectorAll<HTMLElement>('.portfolio-card');
      gridCards.forEach(c => { c.style.opacity = '0'; c.style.transform = 'translateY(8px)'; });
      requestAnimationFrame(() => {
        gridCards.forEach((c, i) => {
          setTimeout(() => { c.style.opacity = '1'; c.style.transform = 'translateY(0)'; }, i * 50);
        });
      });
    }, 250);
  }

  backBtn.onclick = handleBackToGrid;

  document.querySelectorAll<HTMLButtonElement>('.portfolio-card').forEach(card => {
    card.addEventListener('click', () => {
      const category = card.dataset.category!;
      overlayTitle.textContent = titles[category] ?? category;
      projectList.innerHTML = '';
      projectList.className = 'portfolio-project-list';
      if (listData[category]) renderList(listData[category]);

      const gridCards = portfolioGrid.querySelectorAll<HTMLElement>('.portfolio-card');
      gridCards.forEach(c => { c.style.opacity = '0'; c.style.transform = 'translateY(8px)'; });
      setTimeout(() => {
        portfolioGrid.style.visibility = 'hidden';
        portfolioHeading.style.visibility = 'hidden';
        overlay.style.display = 'flex';
        const items = projectList.querySelectorAll<HTMLElement>('.portfolio-project-item');
        requestAnimationFrame(() => {
          items.forEach((item, i) => {
            setTimeout(() => { item.style.opacity = '1'; item.style.transform = 'translateY(0)'; }, i * 80);
          });
        });
      }, 250);
    });
  });
</script>

<script>
  (function () {
    const canvas = document.getElementById('portal-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const SIZE = 500;
    canvas.width = SIZE;
    canvas.height = SIZE;

    const TWO_PI = Math.PI * 2;
    const max = 100;
    let hue = 110;
    const particles: Particle[] = [];

    function rnd(min: number, max?: number) {
      if (max === undefined) { max = min; min = 0; }
      return Math.random() * (max - min) + min;
    }

    class Particle {
      r = 0; x = 0; y = 0; vx = 0; vy = 0;
      color = ''; life = 0; maxLife = 0;
      init() {
        this.r = rnd(200) + 100;
        this.x = SIZE / 2;
        this.y = SIZE / 2;
        this.vx = rnd(-2, 2);
        this.vy = rnd(-2, 2);
        this.color = `hsla(${hue}, 100%, 50%, .02)`;
        this.life = 0;
        this.maxLife = rnd(100);
      }
      draw() {
        ctx.strokeStyle = this.color;
        ctx.beginPath();
        ctx.globalCompositeOperation = 'lighter';
        ctx.arc(this.x, this.y, this.r, 0, TWO_PI);
        ctx.stroke();
        this.x += this.vx;
        this.y += this.vy;
        this.life++;
        if (this.life >= this.maxLife || this.r <= 0.2) this.init();
      }
    }

    for (let i = 0; i < max; i++) {
      setTimeout(() => {
        const p = new Particle();
        p.init();
        particles.push(p);
      }, i * 5);
    }

    function loop() {
      ctx.fillStyle = 'rgba(0,0,0,.05)';
      ctx.globalCompositeOperation = 'source-over';
      ctx.fillRect(0, 0, SIZE, SIZE);
      for (const p of particles) p.draw();
      requestAnimationFrame(loop);
    }
    loop();
  })();
</script>

</BaseLayout>
