<script>
  const starsContainer = document.getElementById('stars-container')!;

  function spawnStar() {
    const star = document.createElement('span');
    star.classList.add('shooting-star');
    star.style.top = '0%';
    star.style.left = `${10 + Math.random() * 80}%`;
    const dur = 1.5 + Math.random() * 0.5;
    star.style.animationDuration = `${dur}s`;
    starsContainer.appendChild(star);
    star.addEventListener('animationend', () => star.remove());
    setTimeout(spawnStar, 4000 + Math.random() * 4000);
  }
  setTimeout(spawnStar, 1000);
  setTimeout(spawnStar, 3000);

  const hamburger = document.getElementById('hamburger')!;
  const navLinksWrap = document.getElementById('nav-links')!;

  const backdrop = document.createElement('div');
  backdrop.style.cssText = `
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,0.55); z-index: 9998;
    transition: opacity 0.3s ease;
    opacity: 0;
  `;
  document.body.appendChild(backdrop);

  function closeMenu() {
    navLinksWrap.classList.add('closing');
    backdrop.style.opacity = '0';
    setTimeout(() => {
      hamburger.classList.remove('open');
      navLinksWrap.classList.remove('open');
      navLinksWrap.classList.remove('closing');
      backdrop.style.display = 'none';
    }, 280);
  }

  backdrop.addEventListener('click', closeMenu);

  hamburger.addEventListener('click', (e) => {
    e.stopPropagation();
    if (navLinksWrap.classList.contains('open')) {
      closeMenu();
    } else {
      if (navLinksWrap.parentElement !== document.body) {
        document.body.appendChild(navLinksWrap);
      }
      backdrop.style.display = 'block';
      requestAnimationFrame(() => { backdrop.style.opacity = '1'; });
      hamburger.classList.add('open');
      navLinksWrap.classList.add('open');
    }
  });

  document.addEventListener('click', (e) => {
    if (navLinksWrap.classList.contains('open') && !navLinksWrap.contains(e.target as Node)) {
      closeMenu();
    }
  });

  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-link');
  const scrollWrap = document.querySelector('.parallax-wrap') as HTMLElement;

  function smoothScrollTo(target: number, duration: number = 1000) {
    const start = scrollWrap.scrollTop;
    const distance = target - start;
    let startTime: number | null = null;

    function step(timestamp: number) {
      if (!startTime) startTime = timestamp;
      const elapsed = timestamp - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const ease = progress < 0.5
        ? 4 * progress * progress * progress
        : 1 - Math.pow(-2 * progress + 2, 3) / 2;
      scrollWrap.scrollTop = start + distance * ease;
      if (elapsed < duration) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  navLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector(link.getAttribute('href')!);
      if (target) {
        smoothScrollTo((target as HTMLElement).offsetTop, 1200);
      }
      closeMenu();
    });
  });

  type ListItem = { name: string; href: string };

